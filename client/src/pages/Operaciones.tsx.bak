      <div className="grid md:grid-cols-2 xl:grid-cols-4 gap-4 mb-5">
        <StatCard icon={ClipboardList} label="Abiertas" value={stats?.abiertas ?? 0} tone="#0A7EA4" />
        <StatCard icon={CalendarDays} label="Pendientes" value={stats?.pendientes ?? 0} tone="#EAB308" />
        <StatCard icon={BriefcaseBusiness} label="En curso" value={stats?.enProgreso ?? 0} tone="#FF6B35" />
        <StatCard icon={BadgeCheck} label="Completadas hoy" value={stats?.completadasHoy ?? 0} tone="#22C55E" />
      </div>

      <div className="grid xl:grid-cols-[1.1fr_0.9fr] gap-4 mb-5">
        <div className="surface-panel rounded-[24px] border border-slate-200 p-4">
          <div className="flex items-start justify-between gap-3 mb-4">
            <div>
              <div className="text-[11px] uppercase tracking-[0.18em] text-slate-400">Atención inmediata</div>
              <h3 className="mt-2 font-heading text-[20px] leading-tight font-semibold text-slate-800">
                Lo que el supervisor debería mirar primero
              </h3>
            </div>
            <div className="rounded-2xl bg-rose-50 text-rose-700 p-3">
              <TriangleAlert size={18} />
            </div>
          </div>

          <div className="grid md:grid-cols-2 gap-3">
            <div className="rounded-[20px] border border-rose-100 bg-rose-50/70 p-4">
              <div className="flex items-center justify-between gap-3">
                <div>
                  <div className="text-[11px] uppercase tracking-[0.18em] text-rose-500">Controles vencidos</div>
                  <div className="mt-2 font-heading text-[30px] leading-none font-semibold text-rose-700">{tareasVencidas.length}</div>
                </div>
                <BellRing size={18} className="text-rose-600" />
