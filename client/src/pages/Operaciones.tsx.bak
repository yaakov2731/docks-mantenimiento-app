            </div>

            <div className="rounded-[20px] border border-amber-100 bg-amber-50/70 p-4">
              <div className="flex items-center justify-between gap-3">
                <div>
                  <div className="text-[11px] uppercase tracking-[0.18em] text-amber-500">Recepción bot</div>
                  <div className="mt-2 font-heading text-[30px] leading-none font-semibold text-amber-700">{recepcionesPendientes.length}</div>
                </div>
                <TimerReset size={18} className="text-amber-600" />
