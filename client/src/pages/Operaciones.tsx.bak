            <div className="mt-4 flex items-center justify-between gap-3">
              <div className="text-xs text-slate-500">
                {empleadoSeleccionadoFormulario ? `Se enviara al bot de ${empleadoSeleccionadoFormulario.nombre} para confirmacion.` : 'Podes crearla sin asignar y derivarla despues.'}
