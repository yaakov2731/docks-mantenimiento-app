                  onChange={e => setForm(prev => ({ ...prev, fechaTrabajo: e.target.value }))}
                  className="w-full border border-slate-200 rounded-2xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary/30"
                />
              </label>
              <label>
                <div className="mb-1.5 text-xs font-medium text-slate-500">Planta</div>
                <select
                  value={form.planta}
                  onChange={e => setForm(prev => ({ ...prev, planta: e.target.value }))}
                  className="w-full border border-slate-200 rounded-2xl px-4 py-3 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-primary/30"
                >
                  <option value="baja">Planta baja</option>
                  <option value="alta">Planta alta</option>
                </select>
              </label>
              <label>
                <div className="mb-1.5 text-xs font-medium text-slate-500">Categoría</div>
                <select
                  value={form.categoria}
                  onChange={e => setForm(prev => ({ ...prev, categoria: e.target.value }))}
                  className="w-full border border-slate-200 rounded-2xl px-4 py-3 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-primary/30"
                >
                  {CATEGORIAS.map(categoria => <option key={categoria.value} value={categoria.value}>{categoria.label}</option>)}
                </select>
              </label>
              <label>
                <div className="mb-1.5 text-xs font-medium text-slate-500">Prioridad</div>
                <select
                  value={form.prioridad}
                  onChange={e => setForm(prev => ({ ...prev, prioridad: e.target.value }))}
                  className="w-full border border-slate-200 rounded-2xl px-4 py-3 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-primary/30"
                >
                  {PRIORIDADES.map(prioridad => <option key={prioridad.value} value={prioridad.value}>{prioridad.label}</option>)}
                </select>
              </label>
              <label>
                <div className="mb-1.5 text-xs font-medium text-slate-500">Asignar a empleado ahora</div>
                <select
                  value={form.empleadoId}
                  onChange={e => setForm(prev => ({ ...prev, empleadoId: e.target.value }))}
                  className="w-full border border-slate-200 rounded-2xl px-4 py-3 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-primary/30"
                >
                  <option value="">Crear sin asignar</option>
