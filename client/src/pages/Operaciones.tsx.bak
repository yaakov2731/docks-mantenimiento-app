function Badge({ value, options }: { value: string; options: readonly { value: string; label: string; color?: string }[] }) {
  const opt = options.find(o => o.value === value)
  return (
    <span
      className="inline-flex px-2 py-0.5 rounded-full text-xs font-medium"
      style={{ backgroundColor: `${opt?.color ?? '#94A3B8'}20`, color: opt?.color ?? '#475569' }}
    >
      {opt?.label ?? value}
    </span>
  )
}

function StatCard({
  icon: Icon,
  label,
  value,
  tone,
}: {
  icon: any
  label: string
  value: string | number
  tone: string
}) {
  return (
    <div className="surface-panel rounded-[22px] border border-slate-200 p-4">
      <div className="flex items-center justify-between gap-3">
        <div>
          <div className="text-[11px] uppercase tracking-[0.18em] text-slate-400">{label}</div>
          <div className="mt-2 font-heading text-[28px] leading-none font-semibold" style={{ color: tone }}>{value}</div>
        </div>
        <div className="rounded-2xl p-3" style={{ backgroundColor: `${tone}14`, color: tone }}>
          <Icon size={20} />
        </div>
      </div>
    </div>
  )
}

function todayKey() {
  return new Date().toISOString().slice(0, 10)
}

function formatDateTime(value?: string | null) {
  if (!value) return 'Sin respuesta'
  const date = new Date(value)
  if (Number.isNaN(date.getTime())) return 'Sin respuesta'
  return date.toLocaleString('es-AR', {
    day: '2-digit',
    month: '2-digit',
    hour: '2-digit',
    minute: '2-digit',
  })
}

function formatScheduleLabel(value?: string | null) {
  if (!value) return 'Disponible ahora'
  const date = new Date(value)
  if (Number.isNaN(date.getTime())) return 'Disponible ahora'
  return date.toLocaleString('es-AR', {
    day: '2-digit',
    month: '2-digit',
    hour: '2-digit',
    minute: '2-digit',
  })
}

function isDueNow(operacion: any) {
  if (!operacion || Number(operacion.recurrenteCadaHoras ?? 0) <= 0) return false
  if (!operacion.proximaRevisionAt) return operacion.estado === 'pendiente'
  const dueAt = new Date(operacion.proximaRevisionAt).getTime()
  return !Number.isNaN(dueAt) && dueAt <= Date.now()
}

function getBotStatusTone(operacion: any) {
  if (operacion.asignacionEstado === 'pendiente_confirmacion') {
    return {
      label: 'Esperando recepción del empleado',
      detail: 'Todavía no confirmó la orden en WhatsApp.',
      chipClass: 'bg-amber-50 text-amber-700 border-amber-200',
    }
  }
  if (operacion.estado === 'en_progreso') {
    return {
      label: 'En foco del equipo',
      detail: operacion.asignadoA ? `${operacion.asignadoA} la está trabajando ahora.` : 'La orden está corriendo.',
      chipClass: 'bg-orange-50 text-orange-700 border-orange-200',
    }
  }
  if (isDueNow(operacion)) {
    return {
      label: 'Control vencido / para ahora',
      detail: 'Conviene revisarla o disparar el seguimiento inmediato.',
      chipClass: 'bg-rose-50 text-rose-700 border-rose-200',
    }
  }
  if (operacion.asignacionEstado === 'aceptada' && operacion.estado === 'pendiente') {
    return {
      label: 'Aceptada y lista para ejecutar',
      detail: 'El empleado ya la tomó y queda disponible para iniciar.',
      chipClass: 'bg-emerald-50 text-emerald-700 border-emerald-200',
    }
  }
  return {
    label: 'En seguimiento',
    detail: operacion.asignadoA ? `Asignada a ${operacion.asignadoA}.` : 'Pendiente de organización.',
    chipClass: 'bg-slate-100 text-slate-700 border-slate-200',
  }
}

export default function Operaciones() {
  const [filters, setFilters] = useState({
    estado: '',
    prioridad: '',
    fechaTrabajo: todayKey(),
    busqueda: '',
  })
  const [selected, setSelected] = useState<number | null>(null)
  const [assigningTo, setAssigningTo] = useState('')
  const [nota, setNota] = useState('')
  const [showNota, setShowNota] = useState(false)
  const [form, setForm] = useState({
    titulo: '',
    descripcion: '',
    ubicacion: '',
    planta: 'baja',
    categoria: 'limpieza',
    prioridad: 'media',
    fechaTrabajo: todayKey(),
    orden: '0',
    checklistObjetivo: '',
    recurrenteCadaHoras: '',
    empleadoId: '',
  })

  const { data: empleados = [] } = trpc.empleados.listar.useQuery()
  const { data: stats } = trpc.operaciones.estadisticas.useQuery(undefined, { refetchInterval: 5000 })
  const { data: operaciones = [], refetch } = trpc.operaciones.listar.useQuery(filters, { refetchInterval: 5000 })
  const { data: operacion } = trpc.operaciones.obtener.useQuery({ id: selected! }, { enabled: !!selected, refetchInterval: 4000 })

  const crear = trpc.operaciones.crear.useMutation({
    onSuccess: () => {
      setForm({
        titulo: '',
        descripcion: '',
        ubicacion: '',
        planta: 'baja',
        categoria: 'limpieza',
        prioridad: 'media',
        fechaTrabajo: todayKey(),
        orden: '0',
        checklistObjetivo: '',
        recurrenteCadaHoras: '',
        empleadoId: '',
      })
      refetch()
    },
  })
  const asignar = trpc.operaciones.asignar.useMutation({ onSuccess: () => { setAssigningTo(''); refetch() } })
  const cambiarEstado = trpc.operaciones.actualizarEstado.useMutation({ onSuccess: () => refetch() })
  const agregarNota = trpc.operaciones.agregarNota.useMutation({
    onSuccess: () => {
      setNota('')
      setShowNota(false)
      refetch()
    },
  })

  const empleadoSeleccionadoFormulario = empleados.find((empleado: any) => String(empleado.id) === form.empleadoId)
  const empleadoSeleccionadoDetalle = empleados.find((empleado: any) => String(empleado.id) === assigningTo)
  const tareasVencidas = operaciones.filter((operacion: any) => isDueNow(operacion) && !['completado', 'cancelado'].includes(operacion.estado))
  const recepcionesPendientes = operaciones.filter((operacion: any) => operacion.asignacionEstado === 'pendiente_confirmacion')
  const focoOperativo = operaciones.filter((operacion: any) =>
    !['completado', 'cancelado'].includes(operacion.estado) &&
    (operacion.estado === 'en_progreso' || (operacion.asignacionEstado === 'aceptada' && operacion.estado === 'pendiente'))
  )

  const applyTemplate = (template: typeof QUICK_TEMPLATES[number]) => {
    setForm(prev => ({
      ...prev,
      titulo: template.titulo,
      descripcion: template.descripcion,
      ubicacion: template.ubicacion,
      planta: template.planta,
      categoria: template.categoria,
      prioridad: template.prioridad,
      checklistObjetivo: template.checklistObjetivo,
      recurrenteCadaHoras: template.recurrenteCadaHoras,
    }))
  }

  return (
    <DashboardLayout title="Operaciones Diarias">
      <div className="surface-panel-strong rounded-[26px] p-5 md:p-6 relative overflow-hidden mb-5">
        <div className="absolute inset-y-0 right-0 w-1/3 bg-[radial-gradient(circle_at_center,rgba(10,126,164,0.10),transparent_72%)] pointer-events-none" />
        <div className="relative grid xl:grid-cols-[1.1fr_0.9fr] gap-5">
          <div>
            <div className="inline-flex items-center gap-2 rounded-full bg-primary/10 px-3 py-1 text-[11px] font-medium text-primary">
              <Sparkles size={14} />
              Operacion interna del predio
            </div>
            <h2 className="mt-3 font-heading text-[22px] md:text-[28px] leading-tight font-semibold text-sidebar-bg">
              Asigna limpieza, pintura, recorridas y mantenimiento general sin mezclarlo con reclamos de locatarios
            </h2>
            <p className="mt-2 max-w-2xl text-[13px] text-slate-600">
              Estas ordenes aparecen en el menu del empleado como tareas operativas. El tecnico puede aceptarlas, reportar avances, pausarlas y cerrarlas desde WhatsApp.
            </p>
          </div>

          <div className="rounded-[24px] bg-white border border-slate-200 p-4 shadow-sm">
            <div className="flex items-center gap-2 text-[11px] uppercase tracking-[0.18em] text-slate-400">
              <Plus size={14} />
              Nueva tarea operativa
            </div>
            <div className="mt-4 rounded-[20px] border border-slate-200 bg-slate-50 p-4">
              <div className="text-[11px] uppercase tracking-[0.18em] text-slate-400">Plantillas rápidas</div>
              <div className="mt-3 grid md:grid-cols-2 gap-2">
                {QUICK_TEMPLATES.map(template => (
                  <button
                    key={template.key}
                    type="button"
                    onClick={() => applyTemplate(template)}
                    className="rounded-[18px] border border-slate-200 bg-white px-3 py-3 text-left hover:border-primary/30 hover:bg-primary/5 transition-all"
                  >
                    <div className="font-medium text-slate-800">{template.title}</div>
                    <div className="mt-1 text-xs text-slate-500">
                      {template.ubicacion} · {template.recurrenteCadaHoras ? `cada ${template.recurrenteCadaHoras}h` : 'a demanda'}
                    </div>
                  </button>
                ))}
              </div>
            </div>
            <div className="grid md:grid-cols-2 gap-3 mt-4">
              <label className="md:col-span-2">
                <div className="mb-1.5 text-xs font-medium text-slate-500">Título de la tarea</div>
                <input
                  value={form.titulo}
                  onChange={e => setForm(prev => ({ ...prev, titulo: e.target.value }))}
                  placeholder="Ej: Limpieza baño de mujeres"
                  className="w-full border border-slate-200 rounded-2xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary/30"
                />
              </label>
              <label>
                <div className="mb-1.5 text-xs font-medium text-slate-500">Ubicación</div>
                <input
                  value={form.ubicacion}
                  onChange={e => setForm(prev => ({ ...prev, ubicacion: e.target.value }))}
                  placeholder="Ej: Baño de mujeres"
