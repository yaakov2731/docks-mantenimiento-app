                    className="w-full text-left rounded-2xl border border-rose-100 bg-white/80 px-3 py-2 hover:bg-white transition-colors"
                  >
                    <div className="text-sm font-medium text-slate-800">{operacion.titulo}</div>
                    <div className="text-xs text-slate-500 mt-1">
                      {operacion.ubicacion} · {operacion.asignadoA ?? 'Sin asignar'}
