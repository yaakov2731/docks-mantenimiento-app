              <Button
                loading={crear.isLoading}
                disabled={!form.titulo || !form.ubicacion || !form.descripcion || !form.fechaTrabajo}
                onClick={() => crear.mutate({
                  titulo: form.titulo,
                  descripcion: form.descripcion,
                  ubicacion: form.ubicacion,
                  planta: form.planta as 'baja' | 'alta',
                  categoria: form.categoria as any,
                  prioridad: form.prioridad as any,
                  fechaTrabajo: form.fechaTrabajo,
                  orden: Number(form.orden || 0),
                  checklistObjetivo: form.checklistObjetivo || undefined,
                  recurrenteCadaHoras: form.recurrenteCadaHoras ? Number(form.recurrenteCadaHoras) : undefined,
                  empleadoId: empleadoSeleccionadoFormulario?.id,
