                  placeholder="Cada cuántas horas se repite. Ej: 2"
                  className="w-full border border-slate-200 rounded-2xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary/30"
                />
              </label>
              <label className="md:col-span-2">
                <div className="mb-1.5 text-xs font-medium text-slate-500">Descripción operativa</div>
                <textarea
                  value={form.descripcion}
                  onChange={e => setForm(prev => ({ ...prev, descripcion: e.target.value }))}
                  placeholder="Qué hay que hacer exactamente, con qué criterio queda terminada y cualquier detalle operativo..."
                  className="w-full border border-slate-200 rounded-2xl px-4 py-3 text-sm min-h-[108px] focus:outline-none focus:ring-2 focus:ring-primary/30"
                />
