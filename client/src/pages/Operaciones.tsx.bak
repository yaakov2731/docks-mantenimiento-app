              <div className="mt-3 space-y-2">
                {recepcionesPendientes.slice(0, 3).map((operacion: any) => (
                  <button
                    key={`ack-${operacion.id}`}
                    onClick={() => setSelected(operacion.id)}
                    className="w-full text-left rounded-2xl border border-amber-100 bg-white/80 px-3 py-2 hover:bg-white transition-colors"
                  >
                    <div className="text-sm font-medium text-slate-800">{operacion.titulo}</div>
                    <div className="text-xs text-slate-500 mt-1">
                      {operacion.asignadoA ?? 'Sin asignar'} · {(operacion as any).asignacionRespondidaAt ? `respondió ${formatDateTime((operacion as any).asignacionRespondidaAt)}` : 'pendiente de respuesta'}
                    </div>
                  </button>
                ))}
                {recepcionesPendientes.length === 0 && (
                  <div className="rounded-2xl border border-dashed border-amber-200 px-3 py-4 text-sm text-amber-700/80">
                    No hay tareas esperando confirmación.
                  </div>
                )}
              </div>
            </div>
          </div>
        </div>

        <div className="surface-panel rounded-[24px] border border-slate-200 p-4">
          <div className="flex items-start justify-between gap-3 mb-4">
            <div>
              <div className="text-[11px] uppercase tracking-[0.18em] text-slate-400">En foco por empleado</div>
              <h3 className="mt-2 font-heading text-[20px] leading-tight font-semibold text-slate-800">
                Lo que ya está tomado por el equipo
              </h3>
            </div>
            <div className="rounded-2xl bg-cyan-50 text-cyan-700 p-3">
              <BriefcaseBusiness size={18} />
            </div>
          </div>

          <div className="space-y-3">
            {focoOperativo.slice(0, 5).map((operacion: any) => {
              const botStatus = getBotStatusTone(operacion)
              return (
                <button
                  key={`focus-${operacion.id}`}
                  onClick={() => setSelected(operacion.id)}
                  className="w-full text-left rounded-[20px] border border-slate-200 bg-white px-4 py-3 hover:shadow-sm transition-all"
                >
                  <div className="flex items-start justify-between gap-3">
                    <div>
                      <div className="font-medium text-slate-800">{operacion.titulo}</div>
                      <div className="text-xs text-slate-500 mt-1">
                        {operacion.asignadoA ?? 'Sin asignar'} · {operacion.ubicacion}
                      </div>
                    </div>
                    <span className={`inline-flex rounded-full border px-2 py-1 text-[11px] font-medium ${botStatus.chipClass}`}>
                      {botStatus.label}
                    </span>
                  </div>
                  <div className="mt-3 flex items-center justify-between gap-3">
                    <div className="text-xs text-slate-500">{botStatus.detail}</div>
                    <div className="text-sm font-medium text-slate-700">
                      <WorkingTime seconds={operacion.tiempoTrabajadoSegundos} isRunning={operacion.estado === 'en_progreso'} />
                    </div>
                  </div>
                </button>
              )
            })}
            {focoOperativo.length === 0 && (
              <div className="rounded-[20px] border border-dashed border-slate-300 bg-slate-50 px-4 py-6 text-sm text-slate-500">
                Todavía no hay tareas tomadas o corriendo. Cuando el personal las acepte desde el bot van a aparecer acá.
              </div>
            )}
          </div>
        </div>
      </div>

      <div className="surface-panel rounded-[24px] overflow-hidden">
        <div className="p-4 border-b border-black/5 flex flex-wrap gap-3 items-center bg-white/70">
          <input
            value={filters.busqueda}
            onChange={e => setFilters(prev => ({ ...prev, busqueda: e.target.value }))}
            placeholder="Buscar titulo, ubicacion o indicacion..."
            className="border border-gray-200 rounded-2xl px-4 py-2.5 text-[13px] flex-1 min-w-48 bg-white focus:outline-none focus:ring-2 focus:ring-primary/30"
          />
          <input
            type="date"
            value={filters.fechaTrabajo}
            onChange={e => setFilters(prev => ({ ...prev, fechaTrabajo: e.target.value }))}
            className="border border-gray-200 rounded-2xl px-4 py-2.5 text-[13px] bg-white focus:outline-none focus:ring-2 focus:ring-primary/30"
          />
          <select
            value={filters.estado}
            onChange={e => setFilters(prev => ({ ...prev, estado: e.target.value }))}
            className="border border-gray-200 rounded-2xl px-4 py-2.5 text-[13px] bg-white focus:outline-none focus:ring-2 focus:ring-primary/30"
          >
            <option value="">Todos los estados</option>
            {ESTADOS.map(estado => <option key={estado.value} value={estado.value}>{estado.label}</option>)}
          </select>
          <select
            value={filters.prioridad}
            onChange={e => setFilters(prev => ({ ...prev, prioridad: e.target.value }))}
            className="border border-gray-200 rounded-2xl px-4 py-2.5 text-[13px] bg-white focus:outline-none focus:ring-2 focus:ring-primary/30"
          >
            <option value="">Todas las prioridades</option>
            {PRIORIDADES.map(prioridad => <option key={prioridad.value} value={prioridad.value}>{prioridad.label}</option>)}
          </select>
          <div className="flex flex-wrap gap-2">
            <button
              type="button"
              onClick={() => setFilters(prev => ({ ...prev, estado: '', prioridad: '' }))}
              className="rounded-full border border-slate-200 bg-white px-3 py-2 text-[12px] font-medium text-slate-600 hover:border-slate-300"
            >
              Ver todo
            </button>
            <button
              type="button"
              onClick={() => setFilters(prev => ({ ...prev, estado: 'pendiente', prioridad: '' }))}
              className="rounded-full border border-amber-200 bg-amber-50 px-3 py-2 text-[12px] font-medium text-amber-700"
            >
              Pendientes
            </button>
            <button
              type="button"
              onClick={() => setFilters(prev => ({ ...prev, estado: 'en_progreso', prioridad: '' }))}
              className="rounded-full border border-orange-200 bg-orange-50 px-3 py-2 text-[12px] font-medium text-orange-700"
            >
              En curso
            </button>
          </div>
        </div>

        <div className="grid lg:grid-cols-2 2xl:grid-cols-3 gap-4 p-4">
          {operaciones.length === 0 ? (
            <div className="lg:col-span-2 2xl:col-span-3 rounded-[22px] border border-dashed border-slate-300 bg-slate-50 p-10 text-center">
              <BriefcaseBusiness className="mx-auto mb-3 text-slate-400" size={36} />
              <div className="font-medium text-slate-700">No hay tareas operativas para este filtro</div>
              <div className="text-sm text-slate-500 mt-1">Crealas arriba para que aparezcan en el panel y en el bot del empleado.</div>
            </div>
          ) : operaciones.map((operacion: any) => (
            <button
              key={operacion.id}
              onClick={() => setSelected(operacion.id)}
              className="text-left rounded-[24px] border border-slate-200 bg-white p-4 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all"
            >
              <div className="mb-3 flex flex-wrap gap-2">
                {(() => {
                  const botStatus = getBotStatusTone(operacion)
                  return (
                    <span className={`inline-flex rounded-full border px-2 py-1 text-[11px] font-medium ${botStatus.chipClass}`}>
                      {botStatus.label}
                    </span>
                  )
                })()}
              </div>
              <div className="flex items-start justify-between gap-3">
                <div>
                  <div className="text-[11px] uppercase tracking-[0.18em] text-slate-400">Orden #{String(operacion.id).padStart(4, '0')}</div>
                  <div className="mt-1 font-heading text-lg font-semibold text-slate-800">{operacion.titulo}</div>
                </div>
                <Badge value={operacion.estado} options={ESTADOS} />
              </div>

              <div className="mt-3 flex flex-wrap gap-2">
                <Badge value={operacion.prioridad} options={PRIORIDADES} />
                <Badge value={operacion.asignacionEstado ?? 'sin_asignar'} options={ESTADOS_ASIGNACION} />
                <span className="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-slate-100 text-slate-600">
                  {CATEGORIAS.find(categoria => categoria.value === operacion.categoria)?.label ?? operacion.categoria}
                </span>
                {operacion.orden > 0 && (
                  <span className="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-cyan-50 text-cyan-700">
                    Orden {operacion.orden}
                  </span>
                )}
                {operacion.recurrenteCadaHoras > 0 && (
                  <span className="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-emerald-50 text-emerald-700">
                    Cada {operacion.recurrenteCadaHoras}h
                  </span>
                )}
                {isDueNow(operacion) && (
                  <span className="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-rose-50 text-rose-700">
                    Para ahora
                  </span>
                )}
              </div>

              <div className="mt-3 space-y-2 text-sm text-slate-600">
                <div className="flex items-center gap-2">
                  <MapPin size={14} />
                  {operacion.ubicacion} · {operacion.planta === 'baja' ? 'Planta baja' : 'Planta alta'}
                </div>
                <div className="flex items-center gap-2">
                  <CalendarDays size={14} />
                  {operacion.fechaTrabajo}
                </div>
                {operacion.checklistObjetivo && (
                  <div className="flex items-center gap-2">
                    <BadgeCheck size={14} />
                    {operacion.checklistObjetivo}
                  </div>
                )}
              </div>

              <div className="mt-3 rounded-[18px] bg-slate-50 border border-slate-200 px-3 py-2">
                <div className="text-[11px] uppercase tracking-[0.18em] text-slate-400">Tiempo operativo</div>
                <div className="mt-1 font-heading text-xl font-semibold text-slate-800">
                  <WorkingTime seconds={operacion.tiempoTrabajadoSegundos} isRunning={operacion.estado === 'en_progreso'} />
                </div>
              </div>

              <div className="mt-3 text-sm text-slate-600 line-clamp-3">{operacion.descripcion}</div>
              <div className="mt-3 text-xs text-slate-500">
                {operacion.asignadoA ? `Asignado a ${operacion.asignadoA}` : 'Sin asignar'}
                {operacion.proximaRevisionAt ? ` · Próxima revisión ${formatScheduleLabel(operacion.proximaRevisionAt)}` : ''}
                {(operacion as any).asignacionRespondidaAt ? ` · Respondida ${formatDateTime((operacion as any).asignacionRespondidaAt)}` : ''}
              </div>
            </button>
          ))}
        </div>
      </div>

      {selected && operacion && (
        <div className="fixed inset-0 bg-black/50 z-50 flex items-end md:items-center justify-center p-0 md:p-4" onClick={() => setSelected(null)}>
          <div className="surface-panel-strong w-full md:max-w-2xl md:rounded-[32px] rounded-t-[32px] max-h-[90vh] overflow-y-auto" onClick={e => e.stopPropagation()}>
            <div className="p-5 border-b border-black/5 flex items-start gap-3">
              <div className="flex-1">
                <div className="text-xs text-gray-400 font-mono mb-1">Orden #{String(operacion.id).padStart(4, '0')}</div>
                <h2 className="font-heading font-bold text-lg">{operacion.titulo}</h2>
                <div className="flex gap-2 mt-2 flex-wrap">
                  <Badge value={operacion.prioridad} options={PRIORIDADES} />
                  <Badge value={operacion.estado} options={ESTADOS} />
                </div>
              </div>
              <button onClick={() => setSelected(null)} className="text-gray-400 hover:text-gray-600"><X size={20} /></button>
            </div>

            <div className="p-5 space-y-4">
              <div className={`rounded-[20px] border px-4 py-3 ${getBotStatusTone(operacion).chipClass}`}>
                <div className="text-[11px] uppercase tracking-[0.18em] opacity-70">Estado operativo actual</div>
                <div className="mt-2 font-heading text-lg font-semibold">{getBotStatusTone(operacion).label}</div>
                <div className="mt-1 text-sm opacity-80">{getBotStatusTone(operacion).detail}</div>
              </div>

              <div>
                <div className="text-xs text-gray-400 uppercase font-medium mb-1">Descripcion operativa</div>
                <p className="text-sm text-gray-700">{operacion.descripcion}</p>
              </div>

              <div className="grid md:grid-cols-2 gap-3 text-sm">
                <div><span className="text-gray-400">Ubicacion:</span> {operacion.ubicacion}</div>
                <div><span className="text-gray-400">Planta:</span> {operacion.planta === 'baja' ? 'Planta baja' : 'Planta alta'}</div>
                <div><span className="text-gray-400">Fecha:</span> {operacion.fechaTrabajo}</div>
                <div><span className="text-gray-400">Orden:</span> {operacion.orden > 0 ? operacion.orden : 'Automático'}</div>
                <div><span className="text-gray-400">Categoria:</span> {CATEGORIAS.find(categoria => categoria.value === operacion.categoria)?.label ?? operacion.categoria}</div>
                <div><span className="text-gray-400">Asignado a:</span> {operacion.asignadoA ?? 'Sin asignar'}</div>
                <div><span className="text-gray-400">Recepcion:</span> <Badge value={operacion.asignacionEstado ?? 'sin_asignar'} options={ESTADOS_ASIGNACION} /></div>
                <div><span className="text-gray-400">Respuesta:</span> {formatDateTime((operacion as any).asignacionRespondidaAt)}</div>
                {operacion.recurrenteCadaHoras > 0 && (
                  <div><span className="text-gray-400">Frecuencia:</span> cada {operacion.recurrenteCadaHoras} horas</div>
                )}
                {operacion.proximaRevisionAt && (
                  <div><span className="text-gray-400">Proxima revision:</span> {formatScheduleLabel(operacion.proximaRevisionAt)}</div>
                )}
                <div><span className="text-gray-400">Bot / empleado:</span> {getBotStatusTone(operacion).detail}</div>
                {operacion.checklistObjetivo && (
                  <div className="md:col-span-2"><span className="text-gray-400">Control:</span> {operacion.checklistObjetivo}</div>
                )}
                <div>
                  <span className="text-gray-400">Tiempo:</span>{' '}
                  <WorkingTime seconds={operacion.tiempoTrabajadoSegundos} isRunning={operacion.estado === 'en_progreso'} className="font-medium text-slate-700" />
                </div>
              </div>

              <div className="flex flex-wrap gap-2 pt-2 border-t">
                {operacion.estado !== 'completado' && (
                  <>
                    {operacion.estado === 'pendiente' && (
                      <Button size="sm" onClick={() => cambiarEstado.mutate({ id: operacion.id, estado: 'en_progreso' })}>
                        Iniciar
                      </Button>
                    )}
                    {operacion.estado === 'en_progreso' && (
                      <Button size="sm" variant="outline" onClick={() => cambiarEstado.mutate({ id: operacion.id, estado: 'pausado' })}>
                        Pausar
                      </Button>
                    )}
                    <Button size="sm" variant="success" onClick={() => cambiarEstado.mutate({ id: operacion.id, estado: 'completado' })}>
                      Completar
                    </Button>
                    <Button size="sm" variant="destructive" onClick={() => cambiarEstado.mutate({ id: operacion.id, estado: 'cancelado' })}>
                      Cancelar
                    </Button>
                  </>
                )}
              </div>

              <div className="flex gap-2">
                <select
                  value={assigningTo}
                  onChange={e => setAssigningTo(e.target.value)}
                  className="flex-1 border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary/50"
                >
                  <option value="">Asignar a empleado...</option>
                  {empleados.map((empleado: any) => (
                    <option key={empleado.id} value={empleado.id}>
                      {empleado.nombre}{empleado.waId ? '' : ' · sin WhatsApp'}
                    </option>
                  ))}
                </select>
                <Button
                  size="sm"
                  variant="secondary"
                  disabled={!empleadoSeleccionadoDetalle}
                  onClick={() => {
                    if (!empleadoSeleccionadoDetalle) return
                    asignar.mutate({
                      id: operacion.id,
                      empleadoId: empleadoSeleccionadoDetalle.id,
                      empleadoNombre: empleadoSeleccionadoDetalle.nombre,
                    })
                  }}
                >
                  Asignar
                </Button>
              </div>

              {showNota ? (
                <div className="flex gap-2">
                  <input
                    value={nota}
                    onChange={e => setNota(e.target.value)}
                    placeholder="Escribi una nota operativa..."
                    className="flex-1 border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary/50"
                  />
                  <Button size="sm" disabled={!nota} onClick={() => agregarNota.mutate({ id: operacion.id, nota })} loading={agregarNota.isLoading}>
                    Guardar
                  </Button>
                  <Button size="sm" variant="ghost" onClick={() => setShowNota(false)}>Cancelar</Button>
                </div>
              ) : (
                <Button size="sm" variant="outline" onClick={() => setShowNota(true)}>+ Agregar nota</Button>
              )}

              {(operacion as any).actualizaciones?.length > 0 && (
                <div>
                  <div className="text-xs text-gray-400 uppercase font-medium mb-3">Bitacora operativa</div>
                  <div className="space-y-2">
                    {(operacion as any).actualizaciones.map((actualizacion: any) => (
                      <div key={actualizacion.id} className="flex gap-3 text-sm">
                        <div className="w-1.5 h-1.5 rounded-full bg-primary mt-2 flex-shrink-0" />
                        <div>
                          <span className="font-medium">{actualizacion.usuarioNombre}</span>
                          <span className="text-gray-400"> · </span>
                          <span className="text-gray-600">{actualizacion.descripcion}</span>
                          <div className="text-xs text-gray-400">{actualizacion.createdAt ? new Date(actualizacion.createdAt).toLocaleString('es-AR') : ''}</div>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              )}
            </div>
          </div>
        </div>
      )}
    </DashboardLayout>
  )
}
